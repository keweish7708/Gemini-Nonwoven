                                <h2 itemprop="name" class="small_h2_font">Nonwoven Acoustic Panel Production Line</h2>
                                <div class="pro_name">Needle punching & thermal bonding combined line for nonwoven production</div>
                                <div class="row">
                                    <div class="col-md-4 order-md-last">
