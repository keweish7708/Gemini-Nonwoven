                              <h2 itemprop="name" class="small_h2_font">Pneumatic Fiber Feeder</h2>
                              <div class="pro_name">Producing uniform fiber batt being fed to carding machine</div>
                                <div class="row">
                                    <div class="col-md-6 order-md-last">
                                        <figure>
                                            <div class="left_pro_img">
