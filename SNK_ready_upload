                              <h2 itemprop="name" class="small_h2_font">Double Cylinder Carding Machine</h2>
                              <div class="pro_name">Carding system for converting fiber batt into fiber web</div>
                                <div class="row">
                                    <div class="col-md-6 order-md-last">
                                        <figure>
                                            <div class="left_pro_img">
                                              <div class="left_pics">
                                                <div class="video_play" data-path="en/czshannuoke/video-double-cylinder-carding-machine_en">
